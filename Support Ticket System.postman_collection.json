          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tickets"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "6"
            },
            {
              "key": "sort",
              "value": "latest"
            }
          ]
        }
      }
    },
    {
